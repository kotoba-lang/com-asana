  "components": {
    "schemas": {
      "Task": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "resourceSubtype": {
            "type": "string",
            "enum": [
              "default_task",
              "milestone",
              "approval",
              "custom"
            ]
          },
          "completed": {
            "type": "boolean"
          },
          "completedAt": {
            "type": "string",
